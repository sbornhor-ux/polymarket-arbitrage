# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# --- Cloudflare R2 (required for DB sync) ---
R2_ACCOUNT_ID=3164db02212ba104d3623df6c4a26a97
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=polymarket-data

# --- OpenAI (required for Trend Analyst + Synthesizer) ---
OPENAI_API_KEY=sk-...

# --- Polygon.io (required for Finance Agent) ---
POLYGON_API_KEY=your_polygon_key

# --- Optional tuning ---
# MIN_MARKET_VOLUME=5000
# MAX_PAGES=10
